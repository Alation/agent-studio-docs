style: {
  fill: "#ffffff"
  stroke: "#e4e4e7"
  border-radius: 16
}

classes: {
  zone: {style: {fill: "#f4f4f5"; stroke: "#71717a"; border-radius: 16; font-color: "#27272a"; bold: true; stroke-width: 2}}
  card: {style: {fill: "#ffffff"; stroke: "#52525b"; border-radius: 12; font-color: "#18181b"; stroke-width: 2}}
  hero: {style: {fill: "#86efac"; stroke: "#166534"; border-radius: 16; font-color: "#14532d"; stroke-width: 2; bold: true}}
  bluezone: {style: {fill: "#eff6ff"; stroke: "#1e40af"; border-radius: 16; font-color: "#1e3a5f"; bold: true; stroke-width: 2}}
  bluecard: {style: {fill: "#dbeafe"; stroke: "#1e40af"; border-radius: 12; font-color: "#1e3a5f"; stroke-width: 2}}
  purplecard: {style: {fill: "#f3e8ff"; stroke: "#6b21a8"; border-radius: 12; font-color: "#3b0764"; stroke-width: 2}}
  person: {style: {fill: "#fde68a"; stroke: "#92400e"; font-color: "#451a03"; bold: true; stroke-width: 2}}
  flow: {style: {stroke: "#52525b"; stroke-width: 2; font-color: "#27272a"; bold: true}}
  okflow: {style: {stroke: "#166534"; stroke-width: 2; font-color: "#14532d"; bold: true}}
  riskflow: {style: {stroke: "#be123c"; stroke-width: 2; font-color: "#9f1239"; bold: true}}
}
